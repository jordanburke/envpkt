{
  "name": "envpkt",
  "version": "0.13.3",
  "description": "Credential lifecycle and fleet management for AI agents",
  "keywords": [
    "credentials",
    "secrets",
    "ai-agents",
    "mcp",
    "toml",
    "fleet-management"
  ],
  "author": "jordan.burke@gmail.com",
  "license": "Apache-2.0",
  "homepage": "https://github.com/jordanburke/envpkt",
  "repository": {
    "type": "git",
    "url": "https://github.com/jordanburke/envpkt"
  },
  "bin": {
    "envpkt": "dist/cli.js"
  },
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "ts-builds build",
    "build:schema": "tsx scripts/build-schema.ts",
    "demo": "tsx scripts/generate-demo-html.ts",
    "dev": "ts-builds dev",
    "docs:dev": "pnpm --dir site dev",
    "docs:build": "pnpm --dir site build",
    "prepublishOnly": "pnpm validate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.49",
    "commander": "^15.0.0",
    "functype": "^1.4.1",
    "functype-log": "^1.4.1",
    "functype-os": "^1.4.1",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "ts-builds": "^3.2.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": "./schemas/envpkt.schema.json"
  },
  "files": [
    "lib",
    "dist",
    "schemas"
  ],
  "prettier": "ts-builds/prettier",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
