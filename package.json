{
  "name": "envpkt",
  "version": "0.13.6",
  "description": "Credential lifecycle and fleet management for AI agents",
  "keywords": [
    "credentials",
    "secrets",
    "ai-agents",
    "mcp",
    "toml",
    "fleet-management"
  ],
  "author": "jordan.burke@gmail.com",
  "license": "Apache-2.0",
  "homepage": "https://github.com/jordanburke/envpkt",
  "repository": {
    "type": "git",
    "url": "https://github.com/jordanburke/envpkt"
  },
  "bin": {
    "envpkt": "dist/cli.js"
  },
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "ts-builds build",
    "build:schema": "tsx scripts/build-schema.ts",
    "demo": "tsx scripts/generate-demo-html.ts",
    "dev": "ts-builds dev",
    "docs:dev": "pnpm --dir site dev",
    "docs:build": "pnpm --dir site build",
    "prepublishOnly": "pnpm validate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.49",
    "commander": "^15.0.0",
    "functype": "^1.5.0",
    "functype-log": "^1.5.0",
    "functype-os": "^1.5.0",
    "smol-toml": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "ts-builds": "^3.2.1",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": "./schemas/envpkt.schema.json"
  },
  "files": [
    "lib",
    "dist",
    "schemas"
  ],
  "prettier": "ts-builds/prettier",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
